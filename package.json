{
	"name": "reputation-system",
	"version": "0.0.1",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reputation-systems/reputation-system.git"
	},
	"homepage": "https://reputation-systems.github.io/reputation-system/",
	"scripts": {
		"test": "vitest",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"package": "svelte-package",
		"postpackage": "node scripts/inline-contracts.js",
		"prepare": "npm run package",
		"pack:tarball": "npm pack --pack-destination .release"
	},
	"devDependencies": {
		"@fleet-sdk/mock-chain": "^0.12.0",
		"@sveltejs/kit": "^1.20.4",
		"@sveltejs/adapter-static": "^2.0.3",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^4.5.2",
		"vitest": "^3.2.4",
		"@sveltejs/package": "^2.5.6"
	},
	"peerDependencies": {
		"svelte": "^4"
	},
	"files": [
		"dist",
		"LIBRARY.md"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"svelte": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"dependencies": {
		"@dagrejs/dagre": "^1.0.4",
		"@fleet-sdk/compiler": "^0.12.0",
		"@fleet-sdk/core": "^0.12.0",
		"@scure/base": "^1.1.3",
		"@types/three": "^0.161.2",
		"@xyflow/svelte": "^0.1.3",
		"update": "^0.7.4",
		"uuid": "^11.0.4"
	}
}
